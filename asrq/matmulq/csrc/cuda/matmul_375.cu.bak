// sm_90 (Hopper) GEMM: TMA + 128B-swizzled SMEM + wgmma, warp-specialized
// (1 producer warpgroup issuing TMA, 2 consumer warpgroups running wgmma).
//
// Block tile: BM=128, BN=256, BK=64.  QSIZE-deep ring buffer in shared memory.
// SMEM layout follows the canonical Hopper 128B-swizzle pattern: each tile is
// presented to TMA as a 3D tensor (k_inner=64, height, width/64) so that the
// 64-fp16 = 128-byte inner row is the swizzle atom.  The matching wgmma
// descriptor uses LBO=16, SBO=1024, swizzle_mode=128B.

#include <cuda.h>
#include <cuda_fp16.h>
#include <cuda_runtime.h>
#include <cstdint>
#include <cstdio>
#include "ptx.h"

namespace ap = asrq_ptx;

// ---------- Tile config ----------
constexpr int BM = 128;
constexpr int BN = 256;
constexpr int BK = 64;
constexpr int QSIZE = 4;
constexpr int K_OUTER_PER_TILE = BK / 64;          // 1

constexpr int NUM_CONSUMERS = 2;        // each owns 64 rows of BM=128
constexpr int NUM_WARPGROUPS = 1 + NUM_CONSUMERS;  // 1 producer + 2 consumer
constexpr int NTHREADS = NUM_WARPGROUPS * 128;     // 384

constexpr int WG_M    = BM / NUM_CONSUMERS;        // 64
constexpr int WGMMA_M = 64;
constexpr int WGMMA_N = 256;                       // single wgmma covers full BN
constexpr int WGMMA_K = 16;
constexpr int FRAGS_K  = BK / WGMMA_K;             // 4

// Per-stage tile sizes (halfs / bytes).
constexpr int A_TILE_HALFS = BM * BK;              // 8192
constexpr int B_TILE_HALFS = BN * BK;              // 16384
constexpr int A_TILE_BYTES = A_TILE_HALFS * 2;     // 16 KB
constexpr int B_TILE_BYTES = B_TILE_HALFS * 2;     // 32 KB
constexpr int STAGE_BYTES  = A_TILE_BYTES + B_TILE_BYTES;  // 48 KB
constexpr int SMEM_BYTES_TILES = QSIZE * STAGE_BYTES;      // 144 KB
constexpr int SMEM_BYTES_BARS  = 2 * QSIZE * (int)sizeof(uint64_t);  // 2 banks
constexpr int SMEM_BYTES = SMEM_BYTES_TILES + SMEM_BYTES_BARS + 128;

// wgmma descriptor params for 128B-swizzled K-major layout.
constexpr uint32_t DESC_LBO_BYTES  = 16;
constexpr uint32_t DESC_SBO_BYTES  = 1024;
constexpr int      DESC_SWIZZLE    = 1;   // 128B

// ---------------------------------------------------------------------------
// Host-side helper: build a CUtensorMap for a row-major (H × W) fp16 matrix,
// viewed as a 3D tensor (k_inner=64, H, W/64) with 128B swizzle.  `box_h`
// is the per-tile rows (BM for A, BN for B); inner box dim is 64, k-outer
// box dim is 1 (BK=64).
// ---------------------------------------------------------------------------
static CUtensorMap make_tensor_map(const __half* ptr, int H, int W, int box_h)
{
    CUtensorMap tm{};
    uint64_t gshape[3]  = {64ull, (uint64_t)H, (uint64_t)(W / 64)};
    uint64_t gstride[2] = {(uint64_t)sizeof(__half) * (uint64_t)W,
                           64ull * sizeof(__half)};
    uint32_t bshape[3]  = {64u, (uint32_t)box_h, (uint32_t)K_OUTER_PER_TILE};
    uint32_t bstride[3] = {1u, 1u, 1u};

    CUresult r = cuTensorMapEncodeTiled(
        &tm,
        CU_TENSOR_MAP_DATA_TYPE_FLOAT16,
        3,
        (void*)ptr,
        gshape,
        gstride,
        bshape,
        bstride,
        CU_TENSOR_MAP_INTERLEAVE_NONE,
        CU_TENSOR_MAP_SWIZZLE_128B,
        CU_TENSOR_MAP_L2_PROMOTION_NONE,
        CU_TENSOR_MAP_FLOAT_OOB_FILL_NONE);
    if (r != CUDA_SUCCESS) {
        const char* err = nullptr;
        cuGetErrorString(r, &err);
        printf("cuTensorMapEncodeTiled failed: %s\n", err ? err : "unknown");
    }
    return tm;
}

// ---------------------------------------------------------------------------
// Triton-style "supergroup" tile swizzle to maximize L2 reuse: traverse tiles
// in column-major within groups of GROUP_M rows of the M-axis, so consecutive
// CTAs scheduled on adjacent SMs share B tiles.
// ---------------------------------------------------------------------------
__device__ __forceinline__ void swizzled_tile(
    int tile_id, int num_m, int num_n, int& block_m, int& block_n)
{
    constexpr int GROUP_M = 8;
    int num_pid_in_group = GROUP_M * num_n;
    int group_id = tile_id / num_pid_in_group;
    int first_pid_m = group_id * GROUP_M;
    int group_size_m = num_m - first_pid_m;
    if (group_size_m > GROUP_M) group_size_m = GROUP_M;
    int tile_in_group = tile_id % num_pid_in_group;
    block_m = first_pid_m + (tile_in_group % group_size_m);
    block_n = tile_in_group / group_size_m;
}

// ---------------------------------------------------------------------------
// Kernel
// ---------------------------------------------------------------------------
__global__ __launch_bounds__(NTHREADS)
void matmul_tc_kernel(
    const __grid_constant__ CUtensorMap tensor_map_A,
    const __grid_constant__ CUtensorMap tensor_map_B,
    __half* __restrict__ C,
    int M, int N, int K,
    int num_tiles_m, int num_tiles_n, int total_tiles)
{
    extern __shared__ __align__(128) uint8_t smem_raw[];
    __half*   sA   = reinterpret_cast<__half*>(smem_raw);
    __half*   sB   = sA + QSIZE * A_TILE_HALFS;
    uint64_t* full  = reinterpret_cast<uint64_t*>(
        smem_raw + SMEM_BYTES_TILES);
    uint64_t* empty = full + QSIZE;

    const int tid = threadIdx.x;
    const int wg  = tid / 128;
    const int wgt = tid % 128;
    const int num_blocks_k = K / BK;     // each iter loads BK=128 cols
    const int sm_id = blockIdx.x;
    const int num_sms = gridDim.x;

    if (tid == 0) {
        #pragma unroll
        for (int i = 0; i < QSIZE; ++i) {
            ap::mbarrier_init(&full[i],  1);
            ap::mbarrier_init(&empty[i], NUM_CONSUMERS);
        }
    }
    __syncthreads();

    if (wg == 0) {
        // ---------------- Producer warpgroup ----------------
        ap::setmaxnreg_dec<40>();
        if (wgt == 0) {
            int p = 0;
            int qidx = 0;
            for (int tile_i = sm_id; tile_i < total_tiles; tile_i += num_sms) {
                int block_m, block_n;
                swizzled_tile(tile_i, num_tiles_m, num_tiles_n, block_m, block_n);
                const int offset_m = block_m * BM;
                const int offset_n = block_n * BN;
                for (int ki = 0; ki < num_blocks_k; ++ki, ++qidx) {
                    if (qidx == QSIZE) { qidx = 0; p ^= 1; }
                    ap::mbarrier_wait(&empty[qidx], p);
                    ap::mbarrier_arrive_expect_tx(
                        &full[qidx],
                        (uint32_t)(A_TILE_BYTES + B_TILE_BYTES));
                    // Each TMA covers K_OUTER_PER_TILE outer 64-col blocks.
                    int c2 = ki * K_OUTER_PER_TILE;
                    ap::tma_load_3d(
                        sA + qidx * A_TILE_HALFS,
                        &tensor_map_A,
                        0, offset_m, c2,
                        &full[qidx]);
                    ap::tma_load_3d(
                        sB + qidx * B_TILE_HALFS,
                        &tensor_map_B,
                        0, offset_n, c2,
                        &full[qidx]);
                }
            }
        }
    } else {
        // ---------------- Consumer warpgroup ----------------
        ap::setmaxnreg_inc<232>();
        const int wg_idx = wg - 1;             // 0 or 1
        const int wg_m_off = wg_idx * WG_M;    // 0 or 64

        // Prime the `empty` barriers so producer can immediately fill all stages.
        if (wgt == 0) {
            #pragma unroll
            for (int i = 0; i < QSIZE; ++i) ap::mbarrier_arrive(&empty[i]);
        }

        const int warp = wgt / 32;
        const int lane = wgt & 31;
        const int r0 = lane / 4;
        const int r1 = r0 + 8;
        const int c0 = (lane % 4) * 2;

        int p = 0;
        int qidx = 0;

        for (int tile_i = sm_id; tile_i < total_tiles; tile_i += num_sms) {
            int block_m, block_n;
            swizzled_tile(tile_i, num_tiles_m, num_tiles_n, block_m, block_n);
            const int offset_m = block_m * BM;
            const int offset_n = block_n * BN;

            float D[128];
            #pragma unroll
            for (int i = 0; i < 128; ++i) D[i] = 0.0f;

            int prev_qidx = -1;
            ap::wgmma_fence();
            for (int ki = 0; ki < num_blocks_k; ++ki, ++qidx) {
                if (qidx == QSIZE) { qidx = 0; p ^= 1; }
                ap::mbarrier_wait(&full[qidx], p);

                __half* sA_q = sA + qidx * A_TILE_HALFS;
                __half* sB_q = sB + qidx * B_TILE_HALFS;
                constexpr int A_OUTER_STRIDE = BM * 64;   // halves between k_outer blocks of A
                constexpr int B_OUTER_STRIDE = BN * 64;   // halves between k_outer blocks of B

                #pragma unroll
                for (int kk = 0; kk < FRAGS_K; ++kk) {
                    int k_outer = kk >> 2;            // 0..K_OUTER_PER_TILE-1
                    int k_inner = (kk & 3) * WGMMA_K; // 0,16,32,48
                    uint64_t a_desc = ap::make_smem_desc(
                        ap::cvta_to_shared(
                            sA_q + k_outer * A_OUTER_STRIDE
                                 + wg_m_off * 64 + k_inner),
                        DESC_LBO_BYTES, DESC_SBO_BYTES, DESC_SWIZZLE);
                    uint64_t b_desc = ap::make_smem_desc(
                        ap::cvta_to_shared(
                            sB_q + k_outer * B_OUTER_STRIDE + k_inner),
                        DESC_LBO_BYTES, DESC_SBO_BYTES, DESC_SWIZZLE);
                    ap::wgmma_m64n256k16_f32_f16_ss<1, 0, 0>(D, a_desc, b_desc);
                }
                ap::wgmma_commit_group();
                ap::wgmma_wait_group<1>();

                if (prev_qidx >= 0 && wgt == 0) ap::mbarrier_arrive(&empty[prev_qidx]);
                prev_qidx = qidx;
            }
            ap::wgmma_wait_group<0>();
            if (prev_qidx >= 0 && wgt == 0) ap::mbarrier_arrive(&empty[prev_qidx]);

            // ---------- Store ----------
            const int warp_row_base = offset_m + wg_m_off + warp * 16;
            const bool full_tile = (offset_m + BM <= M) && (offset_n + BN <= N);

            // m64n256k16 layout: per-thread holds 4 floats per 8-column group,
            // 32 col-groups total (BN=256 / 8) → 128 floats.
            constexpr int N_GROUPS = BN / 8;  // 32
            if (full_tile) {
                #pragma unroll
                for (int g = 0; g < N_GROUPS; ++g) {
                    int gm0 = warp_row_base + r0;
                    int gm1 = warp_row_base + r1;
                    int gn0 = offset_n + g * 8 + c0;
                    __half2 p0 = __floats2half2_rn(D[g*4 + 0], D[g*4 + 1]);
                    __half2 p1 = __floats2half2_rn(D[g*4 + 2], D[g*4 + 3]);
                    *reinterpret_cast<__half2*>(&C[gm0 * N + gn0]) = p0;
                    *reinterpret_cast<__half2*>(&C[gm1 * N + gn0]) = p1;
                }
            } else {
                #pragma unroll
                for (int g = 0; g < N_GROUPS; ++g) {
                    int gm0 = warp_row_base + r0;
                    int gm1 = warp_row_base + r1;
                    int gn0 = offset_n + g * 8 + c0;
                    int gn1 = gn0 + 1;
                    if (gm0 < M && gn0 < N) C[gm0 * N + gn0] = __float2half(D[g*4 + 0]);
                    if (gm0 < M && gn1 < N) C[gm0 * N + gn1] = __float2half(D[g*4 + 1]);
                    if (gm1 < M && gn0 < N) C[gm1 * N + gn0] = __float2half(D[g*4 + 2]);
                    if (gm1 < M && gn1 < N) C[gm1 * N + gn1] = __float2half(D[g*4 + 3]);
                }
            }
        }
    }
}

// ---------------------------------------------------------------------------
// Launcher
// ---------------------------------------------------------------------------
namespace {
struct TmCache {
    const __half* ptr = nullptr;
    int H = 0, W = 0, box_h = 0;
    CUtensorMap tm{};
};
TmCache cache_A, cache_B;

const CUtensorMap& get_tm(TmCache& c, const __half* ptr, int H, int W, int box_h) {
    if (c.ptr != ptr || c.H != H || c.W != W || c.box_h != box_h) {
        c.tm = make_tensor_map(ptr, H, W, box_h);
        c.ptr = ptr; c.H = H; c.W = W; c.box_h = box_h;
    }
    return c.tm;
}

int get_num_sms() {
    static int n = 0;
    if (n == 0) {
        int dev = 0;
        cudaGetDevice(&dev);
        cudaDeviceGetAttribute(&n, cudaDevAttrMultiProcessorCount, dev);
    }
    return n;
}
} // namespace

void matmul_16x16_launcher(
    const __half* A, const __half* B, __half* C, int M, int N, int K)
{
    static bool attr_set = false;
    if (!attr_set) {
        cudaFuncSetAttribute(
            (const void*) matmul_tc_kernel,
            cudaFuncAttributeMaxDynamicSharedMemorySize,
            SMEM_BYTES);
        attr_set = true;
    }

    const CUtensorMap& tmA = get_tm(cache_A, A, M, K, BM);
    const CUtensorMap& tmB = get_tm(cache_B, B, N, K, BN);

    int num_tiles_m = (M + BM - 1) / BM;
    int num_tiles_n = (N + BN - 1) / BN;
    int total_tiles = num_tiles_m * num_tiles_n;
    int num_sms = get_num_sms();
    int grid = total_tiles < num_sms ? total_tiles : num_sms;

    dim3 gridDim(grid);
    dim3 blockDim(NTHREADS);
    matmul_tc_kernel<<<gridDim, blockDim, SMEM_BYTES>>>(
        tmA, tmB, C, M, N, K, num_tiles_m, num_tiles_n, total_tiles);
}
